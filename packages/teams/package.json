{
  "name": "@dexwox/paperclip-plugin-teams",
  "version": "0.1.0",
  "type": "module",
  "description": "Microsoft Teams Chat OS for Paperclip: v1 Adaptive Card notifications via Power Automate Workflows webhooks; v2 interactive bot (approvals, commands) on the Microsoft 365 Agents SDK.",
  "keywords": ["paperclip-plugin", "paperclip", "microsoft-teams", "notifications", "adaptive-cards"],
  "main": "./dist/index.js",
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@paperclipai/plugin-sdk": "*",
    "@paperclipai/shared": "*"
  },
  "devDependencies": {
    "@paperclipai/plugin-sdk": "^2026.403.0",
    "@paperclipai/shared": "^2026.403.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": ["dist/"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DexwoxBusiness/paperclip-plugins.git",
    "directory": "packages/teams"
  },
  "license": "MIT"
}
