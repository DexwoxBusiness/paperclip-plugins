{
  "name": "@dexwox/paperclip-plugin-test-context",
  "version": "0.1.0",
  "type": "module",
  "description": "Test Context Registry for Paperclip: per-project environments, seed manifests, stub maps, secret-ref credentials, ephemeral PR preview envs, and freshness checks - everything an agent needs before generating tests, with secrets never entering prompts.",
  "keywords": ["paperclip-plugin", "paperclip", "testing", "test-context", "playwright"],
  "main": "./dist/index.js",
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@paperclipai/plugin-sdk": "*",
    "@paperclipai/shared": "*"
  },
  "devDependencies": {
    "@paperclipai/plugin-sdk": "^2026.403.0",
    "@paperclipai/shared": "^2026.403.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": ["dist/"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DexwoxBusiness/paperclip-plugins.git",
    "directory": "packages/test-context"
  },
  "license": "MIT"
}
